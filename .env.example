# MT5 Python Connector - Environment Configuration
# Copy this file to .env and configure your settings

# ===================
# MT5 Settings
# ===================
# Path to MT5 terminal executable (Windows)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ===================
# Trading Settings
# ===================
# Default lot size for trades
DEFAULT_LOT=0.1

# Slippage in points
DEFAULT_SLIPPAGE=10

# Magic number for identifying bot's orders
DEFAULT_MAGIC_NUMBER=20240615

# ===================
# Risk Management
# ===================
# Maximum allowed lot size per trade
MAX_LOT_SIZE=1.0

# Maximum number of concurrent positions
MAX_POSITIONS=5

# ===================
# Server Settings
# ===================
# Flask server host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Flask server port
PORT=80

# Enable debug mode (set to False in production!)
DEBUG=False

# ===================
# Security Settings
# ===================
# Enable webhook authentication
ENABLE_AUTH=False

# Bearer token for webhook authentication (generate a secure random string)
# AUTH_TOKEN=your_secret_token_here

# ===================
# Logging Settings
# ===================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=trading.log
